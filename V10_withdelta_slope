            ("📤  PNG",     YELLOW, "#0a0c0f", self._export_png),
            ("📤  CSV",     BORDER, TEXT,      self._export_csv),
        ]:
            tk.Button(tb, text=lbl, font=("Courier New",8,"bold"),
                      bg=bg, fg=fg, relief="flat", cursor="hand2",
                      padx=8, pady=4, command=cmd).pack(side="left", padx=4)
        tk.Label(tb, text="Green = user-measured  ·  Grey = factory  ·  Edit slopes → Refit",
                 font=("Courier New",7), fg=MUTED, bg=PANEL).pack(side="right", padx=12)

        split = tk.Frame(self, bg=BG); split.pack(fill="both", expand=True)
        self._fig  = Figure(facecolor=BG)
        self._canvas = FigureCanvasTkAgg(self._fig, master=split)
        self._canvas.get_tk_widget().pack(side="left", fill="both", expand=True)
        right = tk.Frame(split, bg=PANEL, width=320)
        right.pack(side="right", fill="y"); right.pack_propagate(False)
        self._build_edit_panel(right)

    def _build_edit_panel(self, parent):
        tk.Label(parent, text="  Edit Calibration Slopes",
                 font=("Courier New",9,"bold"), fg=TEAL, bg=PANEL, pady=8).pack(fill="x")
        tk.Frame(parent, bg=BORDER, height=1).pack(fill="x")
        cvs = tk.Canvas(parent, bg=PANEL, highlightthickness=0)
        sb  = ttk.Scrollbar(parent, orient="vertical", command=cvs.yview)
        self._edit_inner = tk.Frame(cvs, bg=PANEL)
        self._edit_inner.bind("<Configure>",
            lambda e: cvs.configure(scrollregion=cvs.bbox("all")))
        cvs.create_window((0,0), window=self._edit_inner, anchor="nw")
        cvs.configure(yscrollcommand=sb.set)
        sb.pack(side="right", fill="y"); cvs.pack(fill="both", expand=True, padx=4, pady=4)
        tk.Button(parent, text="✅  Apply & Refit All",
                  font=("Courier New",9,"bold"), bg=GREEN, fg="#0a0c0f",
                  relief="flat", cursor="hand2", pady=8,
                  command=self._apply_edits).pack(fill="x", padx=8, pady=6)
        tk.Button(parent, text="🏭  Restore Factory Defaults",
                  font=("Courier New",8), bg=RED, fg=TEXT,
                  relief="flat", cursor="hand2", pady=6,
                  command=self._restore_factory).pack(fill="x", padx=8, pady=(0,6))

    def _rebuild_edit_table(self):
        for w in self._edit_inner.winfo_children(): w.destroy()
        self._entry_vars.clear()
        factory_map = {(b,p):s for b,curve in FACTORY_CURVES.items()
                       for s,p in curve}
        for base in sorted(CALIBRATION_CURVES.keys()):
            hdr = tk.Frame(self._edit_inner, bg=DIM); hdr.pack(fill="x", pady=(8,2))
            tk.Label(hdr, text=f"  Baseline: {GAS_NAMES.get(base,str(base))}",
                     font=("Courier New",8,"bold"), fg=TEAL, bg=DIM, pady=4).pack(side="left")
            for slope, ppm in CALIBRATION_CURVES[base]:
                if slope == 0.0: continue
                is_user = factory_map.get((base,ppm), None) != slope
                row = tk.Frame(self._edit_inner, bg=SURFACE2); row.pack(fill="x", pady=1)
                tk.Label(row, text=f"→ {PPM_LABELS.get(ppm,str(ppm))}",
                         font=("Courier New",8), fg=MUTED, bg=SURFACE2,
                         width=10, anchor="w", padx=6).pack(side="left")
                var = tk.StringVar(value=f"{slope:.4f}")
                self._entry_vars[(base,ppm)] = var
                tk.Entry(row, textvariable=var, width=10,
                         bg=DIM if is_user else BORDER,
                         fg=GREEN if is_user else TEXT,
                         insertbackground=TEXT, relief="flat",
                         font=("Courier New",9)).pack(side="left", padx=4, pady=3)
                tk.Label(row, text="★USER" if is_user else "fac",
                         font=("Courier New",7),
                         fg=GREEN if is_user else MUTED,
                         bg=SURFACE2, padx=4).pack(side="right")

    def _apply_edits(self):
        for (base,ppm),var in self._entry_vars.items():
            try:
                CAL_MGR.update_single_point(base, ppm, float(var.get()))
            except ValueError:
                messagebox.showerror("Invalid value",
                    f"Bad slope for base={base} → {ppm} ppm: '{var.get()}'")
                return
        CAL_MGR._autosave(); self.refresh()

    def _restore_factory(self):
        if not messagebox.askyesno("Restore factory","Reset all slopes to factory defaults?"):
            return
        global CALIBRATION_CURVES
        CALIBRATION_CURVES = copy.deepcopy(FACTORY_CURVES)
        CAL_MGR._autosave(); self.refresh()

    def refresh(self):
        self._draw_curves(); self._rebuild_edit_table()

    def _draw_curves(self):
        self._fig.clear()
        states  = sorted(CALIBRATION_CURVES.keys())
        n       = len(states); cols_n = 3; rows_n = math.ceil(n/cols_n)
        fit_type= self._fit_type.get()
        factory_map = {(b,p):s for b,c in FACTORY_CURVES.items() for s,p in c}
        for idx, base in enumerate(states):
            ax = self._fig.add_subplot(rows_n, cols_n, idx+1)
            ax.set_facecolor(SURFACE)
            for sp in ax.spines.values(): sp.set_color(BORDER)
            ax.tick_params(colors=MUTED, labelsize=6)
            ax.set_title(f"Base: {GAS_NAMES.get(base,str(base))}",
                         fontsize=7, color=MUTED, fontfamily="monospace")
            ax.set_xlabel("ppm",fontsize=6,color=MUTED)
            ax.set_ylabel("dV/dt (mV/s)",fontsize=6,color=MUTED)
            ax.grid(True, color=BORDER, lw=0.4, ls="--", alpha=0.5)
            curve  = CALIBRATION_CURVES[base]
            slopes = [p[0] for p in curve if p[0]>0]
            ppms   = [p[1] for p in curve if p[0]>0]
            if not slopes: continue
            for s,p in zip(slopes,ppms):
                is_user = factory_map.get((base,p),None) != s
                ax.scatter(p, s, color=GREEN if is_user else MUTED,
                           s=40, zorder=5, edgecolors=SURFACE, linewidths=1)
                ax.annotate(PPM_LABELS.get(p,str(p)), xy=(p,s),
                            xytext=(4,3), textcoords="offset points",
                            fontsize=5, color=MUTED)
            p_arr = np.array(ppms,dtype=float); s_arr = np.array(slopes,dtype=float)
            xfit  = np.linspace(p_arr.min(), p_arr.max()*1.05, 200)
            try:
                if fit_type=="linear-interp":
                    ax.plot(xfit, np.interp(xfit,p_arr,s_arr), color=ACCENT, lw=1.2)
                elif fit_type=="power-law" and len(p_arr)>=2:
                    c = np.polyfit(np.log10(np.clip(p_arr,1,None)),
                                   np.log10(np.clip(s_arr,0.01,None)),1)
                    ax.plot(xfit, 10**c[1]*xfit**c[0], color=PURPLE, lw=1.2,
                            label=f"b={c[0]:.2f}")
                    ax.legend(facecolor=SURFACE,labelcolor=TEXT,fontsize=5)
                elif fit_type=="michaelis-menten" and len(p_arr)>=2:
                    def mm(x,Vm,Km): return Vm*x/(Km+x)
                    popt,_=curve_fit(mm,p_arr,s_arr,
                                     p0=[s_arr.max()*1.5,p_arr.mean()],
                                     maxfev=5000,bounds=([0,0],[1e6,1e8]))
                    ax.plot(xfit,mm(xfit,*popt),color=TEAL,lw=1.2,
                            label=f"Vm={popt[0]:.0f}")
                    ax.legend(facecolor=SURFACE,labelcolor=TEXT,fontsize=5)
            except Exception: pass
        self._fig.set_facecolor(BG)
        self._fig.subplots_adjust(hspace=0.55,wspace=0.35,
                                   left=0.08,right=0.97,top=0.94,bottom=0.08)
        self._canvas.draw_idle()

    def _export_png(self):
        path=filedialog.asksaveasfilename(defaultextension=".png",filetypes=[("PNG","*.png")])
        if not path: return
        self._fig.savefig(path,dpi=150,bbox_inches="tight",facecolor=BG)
        messagebox.showinfo("Saved",f"PNG saved to:\n{path}")

    def _export_csv(self):
        path=filedialog.asksaveasfilename(defaultextension=".csv",filetypes=[("CSV","*.csv")])
        if not path: return
        CAL_MGR.export_csv(path)
        messagebox.showinfo("Saved",f"CSV saved to:\n{path}")


