    def _open_sim(self):
        w=tk.Toplevel(self); w.title("Simulator"); w.configure(bg=PANEL)
        w.geometry("720x540"); w.grab_set()
        tk.Label(w,text="Gas Exposure Scenario Builder",bg=PANEL,fg=TEXT,
                 font=("Courier New",11,"bold"),pady=8).pack()
        PRESETS={
            "Multi-conc":[(0,60),(100,90),(0,90),(1000,90),(0,90),(10000,90),(0,90),(20000,90),(0,90)],
            "3× 1000ppm":[(0,60),(1000,120),(0,90),(1000,120),(0,90),(1000,120),(0,90)],
            "100→1000":  [(0,60),(100,120),(0,60),(1000,120),(0,90)],
        }
        step_rows=[]
        pf=tk.Frame(w,bg=PANEL); pf.pack(pady=4)
        tk.Label(pf,text="Preset:",bg=PANEL,fg=SUB,font=("Courier New",8)).pack(side="left",padx=4)
        sf=tk.Frame(w,bg=BG); sf.pack(fill="both",expand=True,padx=10,pady=4)
        cv=tk.Canvas(sf,bg=BG,highlightthickness=0)
        sb2=ttk.Scrollbar(sf,orient="vertical",command=cv.yview)
        inner=tk.Frame(cv,bg=BG)
        inner.bind("<Configure>",lambda e:cv.configure(scrollregion=cv.bbox("all")))
        cv.create_window((0,0),window=inner,anchor="nw")
        cv.configure(yscrollcommand=sb2.set)
        sb2.pack(side="right",fill="y"); cv.pack(fill="both",expand=True)
        def draw_hdr():
            for c,(t,wd) in enumerate([("Step",5),("ppm",20),("Duration (s)",12),("",4)]):
                tk.Label(inner,text=t,bg=BORDER,fg=ACCENT,
                         font=("Courier New",8,"bold"),width=wd,pady=3
                         ).grid(row=0,column=c,sticky="ew",padx=1,pady=1)
        def add_row(ppm=0,dur=60):
            ri=len(step_rows)+1
            tk.Label(inner,text=str(ri),bg=BG,fg=SUB,
                     font=("Courier New",8),width=5).grid(row=ri,column=0,padx=1,pady=1)
            pv=tk.StringVar(value=str(ppm)); dv=tk.StringVar(value=str(dur))
            ttk.Combobox(inner,textvariable=pv,
                         values=["0","100","1000","5000","10000","20000"],
                         width=18,font=("Courier New",9)).grid(row=ri,column=1,padx=1,pady=1)
            tk.Entry(inner,textvariable=dv,width=12,bg=BORDER,fg=TEXT,
                     insertbackground=TEXT,relief="flat",
                     font=("Courier New",9)).grid(row=ri,column=2,padx=1,pady=1)
            def rm(pv_=pv):
                idx2=next((i for i,(p,d) in enumerate(step_rows) if p is pv_),None)
                if idx2 is not None: step_rows.pop(idx2)
                for ww in inner.winfo_children(): ww.destroy()
                draw_hdr()
                for p,d in step_rows: add_row(p.get(),d.get())
            tk.Button(inner,text="✕",command=rm,bg=RED,fg=BG,
                      font=("Courier New",8),relief="flat",padx=4
                      ).grid(row=ri,column=3,padx=1)
            step_rows.append((pv,dv))
        def apply_preset(steps):
            for ww in inner.winfo_children(): ww.destroy()
            step_rows.clear(); draw_hdr()
            for ppm,dur in steps: add_row(ppm,dur)
        for name,steps in PRESETS.items():
            tk.Button(pf,text=name,command=lambda s=steps:apply_preset(s),
                      bg=BORDER,fg=TEXT,font=("Courier New",8),
                      relief="flat",padx=5,pady=2).pack(side="left",padx=2)
        draw_hdr()
        for ppm,dur in PRESETS["Multi-conc"]: add_row(ppm,dur)
        cfg=tk.Frame(w,bg=PANEL); cfg.pack(pady=4)
        def ent(val,wd=8):
            v=tk.StringVar(value=val)
            tk.Entry(cfg,textvariable=v,width=wd,bg=BORDER,fg=TEXT,
                     insertbackground=TEXT,relief="flat",font=("Courier New",9)).pack(side="left")
            return v
        for lbl in ["Baseline (mV):","Noise σ:","Speed ms/samp:"]:
            tk.Label(cfg,text=lbl,bg=PANEL,fg=SUB,font=("Courier New",8)).pack(side="left",padx=(8,2))
        bl_v=ent("28.0"); ns_v=ent("0.08"); sp_v=ent("50",6)
        bf=tk.Frame(w,bg=PANEL); bf.pack(pady=6)
        tk.Button(bf,text="➕  Add Step",bg=ACCENT,fg=BG,font=("Courier New",9,"bold"),
                  relief="flat",cursor="hand2",padx=10,pady=4,
                  command=lambda:add_row()).pack(side="left",padx=4)
        def run_sim():
            steps=[]
            for pv,dv in step_rows:
                try: steps.append((float(pv.get()),float(dv.get())))
                except: pass
            if not steps: messagebox.showwarning("Empty","Add steps.",parent=w); return
            try: bl=float(bl_v.get())
            except: bl=28.0
            try: ns=float(ns_v.get())
            except: ns=0.08
            try: sp=max(10,int(sp_v.get()))
            except: sp=50
            t_arr,v_arr,lbl_arr=self._sim.generate(steps,bl,ns)
            w.destroy(); self._launch_sim(t_arr,v_arr,lbl_arr,sp)
        tk.Button(bf,text="▶  Run Simulation",bg=GREEN,fg=BG,
                  font=("Courier New",10,"bold"),relief="flat",cursor="hand2",
                  padx=14,pady=5,command=run_sim).pack(side="left",padx=4)
        tk.Button(bf,text="Cancel",bg=BORDER,fg=TEXT,font=("Courier New",9),
                  relief="flat",cursor="hand2",padx=10,pady=5,
                  command=w.destroy).pack(side="left",padx=2)

    def _start_live(self):
        path=filedialog.askopenfilename(
            title="Open Smart Probe log",filetypes=[("Log","*.log *.txt"),("All","*.*")])
        if not path: return
        self._stop_all(); self._det.reset()
        self._det.set_initial_baseline(CAL_MGR.cal_baseline_mv); self._clear_hist()
        self._tailer=LogTailer(path); self._tailer.start()
        self._mode="live"; self._status.set(f"Live: {os.path.basename(path)}")
        self._start_scheduled_redraw(); self._tick_live()

    def _tick_live(self):
        if self._mode!="live": return
        for v in self._tailer.get_new(): self._ingest(v)
        self._ingest_job=self.after(80,self._tick_live)

    def _launch_sim(self,t_arr,v_arr,lbl_arr,spd):
        self._stop_all(); self._det.reset()
        self._det.set_initial_baseline(CAL_MGR.cal_baseline_mv); self._clear_hist()
        self._sim_t=t_arr; self._sim_v=v_arr
        self._sim_lbl=lbl_arr; self._sim_idx=0; self._sim_spd=spd
        self._mode="simulate"
        self._status.set(f"Simulating {len(t_arr)} samples ({t_arr[-1]:.0f}s)")
        self._nb.select(2); self._start_scheduled_redraw(); self._tick_sim()

    def _tick_sim(self):
        if self._mode!="simulate": return
        if self._sim_idx>=len(self._sim_v):
            self._status.set("Simulation complete."); return
        self._ingest(self._sim_v[self._sim_idx])
        self._sim_idx+=1; self._ingest_job=self.after(self._sim_spd,self._tick_sim)

    def _ingest(self,v_mv):
        res=self._det.push(v_mv); self._tel+=DT
        self._ht.append(self._tel); self._hv.append(v_mv)
        self._hd.append(res["diff_mvs"]); self._hp.append(res["ppm"])
        self._hpd.append(res["ppm_dv"]); self._hbl.append(res["baseline"])
        self._hst.append(res["state"]); self._redraw_dirty=True
        st=res["state"]; ppm=res["ppm"]
        col=ppm_color(ppm) if st in ("GAS_ON","FALLING") else GREEN
        self._ppm_str.set(f"{ppm:.0f}"); self._ppm_lbl.config(fg=col)
        self._label_str.set(res["label"])
        self._band_str.set("✓ SNAP" if (ppm>10 and st=="GAS_ON" and res["in_band"])
                           else ("↗ INTERP" if (ppm>10 and st=="GAS_ON") else ""))
        self._state_str.set(st); self._state_lbl.config(bg=STATE_COL.get(st,GREEN))
        self._regime_str.set(res["regime"]); self._regime_lbl.config(fg=res["regime_col"])
        frac=min(1.0,self._det._measuring_count/SLOPE_WIN)
        self._timer_cv.coords(self._timer_bar,0,0,int(240*frac),10)
        self._timer_cv.itemconfig(self._timer_bar,
            fill=YELLOW if st=="MEASURING" else BORDER)
        ms=res["rates"]["10pt"]
        disc=predict_discrete_state(self._det.cur_ppm,ms)
        smooth=piecewise_interp_2D(self._det.cur_ppm,ms) if ms>0 else 0.0
        self._mvar["V (mV)"].set(f"{v_mv:+.2f}")
        self._mvar["Baseline (mV)"].set(f"{res['baseline']:.2f}")
        self._mvar["Locked BL"].set(f"{res['locked_bl']:.2f}")
        self._mvar["Meas.Sample"].set(f"{self._det._measuring_count}/{SLOPE_WIN}")
        self._mvar["Rate (mV/s)"].set(f"{res['diff_mvs']:+.2f}")
        self._mvar["Elapsed (s)"].set(f"{self._tel:.1f}")
        self._mvar["Max Slope"].set(f"{ms:.3f}")
        self._mvar["Discrete Hit"].set(f"{disc} ppm" if disc else "none")
        self._mvar["Smooth ppm"].set(f"{smooth:.1f}")
        ev=res.get("event")
        if ev and ev["kind"]=="GAS_DETECTED":
            self._tree.insert("","0",values=(
                f"{self._tel:.1f}",ev["kind"],f"{ppm:.0f}",
                str(self._det.cur_ppm),f"{ms:.2f}",
                "SNAP" if res["in_band"] else "INTERP",
                res["regime"],ev["note"]))

    def _start_scheduled_redraw(self):
        if self._redraw_job: self.after_cancel(self._redraw_job)
        self._redraw_job=self.after(self.REDRAW_MS,self._redraw_tick)

    def _redraw_tick(self):
        if self._redraw_dirty:
            self._redraw_dirty=False; self._redraw()
        if self._mode!="idle":
            self._redraw_job=self.after(self.REDRAW_MS,self._redraw_tick)

    def _redraw(self):
        if not self._ht: return
        t=list(self._ht); v=list(self._hv); d=list(self._hd)
        pp=list(self._hp); pd=list(self._hpd); bl=list(self._hbl)
        self._ln_v.set_data(t,v); self._ln_bl.set_data(t,bl)
        self._ln_d.set_data(t,d); self._ln_ppm.set_data(t,pp)
        self._ln_ppd.set_data(t,pd); self._ln_r.set_data(t,d)
        for ax,vals in [(self.ax_v,v),(self.ax_ppm,pp)]:
            ax.set_xlim(t[0],max(t[-1],t[0]+5))
            rng=max(vals)-min(vals); pad=max(rng*0.12,1.0)
            ax.set_ylim(min(vals)-pad,max(vals)+pad)
        for ax,vals in [(self.ax_d,d),(self.ax_r,d)]:
            ax.set_xlim(t[0],max(t[-1],t[0]+5))
            dm=max(abs(x) for x in vals) if vals else 2.0
            ax.set_ylim(-max(dm*1.3,3.0),max(dm*1.3,3.0))
        self.canvas.draw_idle()

    def _stop_all(self):
        if self._ingest_job: self.after_cancel(self._ingest_job); self._ingest_job=None
        if self._redraw_job: self.after_cancel(self._redraw_job); self._redraw_job=None
        if self._tailer:     self._tailer.stop(); self._tailer=None
        self._mode="idle"

    def _do_reset(self):
        self._stop_all(); self._det.reset()
        self._det.set_initial_baseline(CAL_MGR.cal_baseline_mv); self._clear_hist()
        self._ppm_str.set("0"); self._ppm_lbl.config(fg=GREEN)
        self._label_str.set("Air / ambient"); self._band_str.set("")
        self._state_str.set("WARMUP"); self._state_lbl.config(bg=ACCENT)
        self._regime_str.set("—"); self._regime_lbl.config(fg=SUB)
        self._timer_cv.coords(self._timer_bar,0,0,0,10)
        for v in self._mvar.values(): v.set("—")
        for row in self._tree.get_children(): self._tree.delete(row)
        self._status.set("Reset.")

    def _clear_hist(self):
        for buf in (self._ht,self._hv,self._hd,self._hp,self._hpd,self._hbl,self._hst):
            buf.clear()
        self._tel=0.0
        for ax in (self.ax_v,self.ax_d,self.ax_r,self.ax_ppm): ax.cla(); self._sax(ax)
        thresh=ONSET_THRESH/DT; slow=SLOW_THRESH/DT
        self.ax_d.axhline( thresh,color=GREEN, lw=0.7,ls="--",alpha=0.7)
        self.ax_d.axhline( slow,  color=YELLOW,lw=0.7,ls=":", alpha=0.7)
        self.ax_d.axhline(-thresh,color=RED,   lw=0.7,ls="--",alpha=0.7)
        self.ax_d.axhline(0,color=BORDER,lw=0.7,ls="--")
        self.ax_r.axhline(40,color=GREEN, lw=0.7,ls="--",alpha=0.5)
        self.ax_r.axhline(10,color=YELLOW,lw=0.7,ls="--",alpha=0.5)
        for pr,lr in [(100,"100"),(1000,"1k"),(10000,"1%")]:
            self.ax_ppm.axhline(pr,color=SUB,lw=0.5,ls=":",alpha=0.5)
            self.ax_ppm.text(0.5,pr*1.03,lr,color=SUB,fontsize=6,
                             va="bottom",transform=self.ax_ppm.get_yaxis_transform())
        self._ln_v,  =self.ax_v.plot([],[],  color=ACCENT,lw=0.9,label="V")
        self._ln_bl, =self.ax_v.plot([],[],  color=ORANGE,lw=0.9,ls="--",alpha=0.7,label="Baseline")
        self._ln_d,  =self.ax_d.plot([],[],  color=YELLOW,lw=0.9)
        self._ln_r,  =self.ax_r.plot([],[],  color=ACCENT,lw=1.0)
        self._ln_ppm,=self.ax_ppm.plot([],[],color=RED,   lw=1.6,label="2D ppm")
        self._ln_ppd,=self.ax_ppm.plot([],[],color=ACCENT,lw=0.9,ls="--",alpha=0.5)
        self.ax_v.legend(facecolor=PANEL,labelcolor=TEXT,fontsize=7,loc="upper left")
        self.canvas.draw()

    def _sax(self,ax):
        ax.set_facecolor(BG)
        for sp in ax.spines.values(): sp.set_edgecolor(BORDER)
        ax.tick_params(colors=TEXT,labelsize=7)
        ax.xaxis.label.set_color(TEXT); ax.yaxis.label.set_color(TEXT)
        ax.title.set_color(TEXT)
        ax.grid(True,color=PANEL,lw=0.5,ls="--",alpha=0.8)

    def _export_csv(self):
        if not self._ht: messagebox.showinfo("No data","Run first."); return
        path=filedialog.asksaveasfilename(defaultextension=".csv",filetypes=[("CSV","*.csv")])
        if not path: return
        with open(path,"w",newline="") as f:
            w=csv.writer(f)
            w.writerow(["t_s","v_mv","dvdt_mVs","ppm","baseline_mv","state"])
            for t,v,d,p,b,s in zip(self._ht,self._hv,self._hd,self._hp,self._hbl,self._hst):
                w.writerow([f"{t:.4f}",f"{v:.4f}",f"{d:.4f}",f"{p:.1f}",f"{b:.4f}",s])
        self._status.set(f"Exported → {os.path.basename(path)}")

    def _save_png(self):
        path=filedialog.asksaveasfilename(defaultextension=".png",filetypes=[("PNG","*.png")])
        if not path: return
        self.fig.savefig(path,dpi=150,bbox_inches="tight",facecolor=BG)
        self._status.set(f"Saved → {os.path.basename(path)}")

    def _on_close(self):
        self._wizard.on_destroy(); self._stop_all(); plt.close("all"); self.destroy()


