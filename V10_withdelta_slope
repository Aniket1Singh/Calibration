    # ── CHART ─────────────────────────────────────────────────────────────────
    def _build_chart(self, parent):
        card = self._card(parent, "LIVE SIGNAL  —  V (mV) and dV/dt during calibration")
        card.pack(fill="both", expand=True)
        self._fig = Figure(figsize=(6,4), facecolor=SURFACE)
        gs2 = self._fig.add_gridspec(2,1, hspace=0.48,
                                     left=0.10, right=0.97, top=0.92, bottom=0.10)
        self._ax_v    = self._fig.add_subplot(gs2[0])
        self._ax_dvdt = self._fig.add_subplot(gs2[1])
        for ax in (self._ax_v, self._ax_dvdt):
            ax.set_facecolor(SURFACE)
            ax.grid(True, color=BORDER, lw=0.5, ls="--", alpha=0.5)
            for sp in ax.spines.values(): sp.set_color(BORDER)
            ax.tick_params(colors=MUTED, labelsize=8)
        self._ax_v.set_title("Sensor V (mV)", fontsize=9, color=MUTED, fontfamily="monospace")
        self._ax_dvdt.set_title("dV/dt (mV/s)  — teal=fast threshold  yellow=slow threshold",
                                fontsize=8, color=MUTED, fontfamily="monospace")
        self._ax_dvdt.set_xlabel("Elapsed time (s)", fontsize=8, color=MUTED)
        self._ax_dvdt.axhline(ONSET_THRESH/DT, color=TEAL,   lw=1.0, ls="--", alpha=0.8, label=f"fast >{ONSET_THRESH/DT:.0f}")
        self._ax_dvdt.axhline(SLOW_THRESH/DT,  color=YELLOW, lw=0.8, ls=":",  alpha=0.7, label=f"slow >{SLOW_THRESH/DT:.0f}")
        self._ax_dvdt.axhline(0, color=BORDER, lw=0.6, ls="--")
        self._ax_dvdt.legend(facecolor=SURFACE, labelcolor=MUTED, fontsize=7, loc="upper left")
        self._ln_v,    = self._ax_v.plot([], [], color=ACCENT, lw=1.0)
        self._ln_dvdt, = self._ax_dvdt.plot([], [], color=TEAL, lw=1.0)
        self._canvas_cal = FigureCanvasTkAgg(self._fig, master=card)
        self._canvas_cal.get_tk_widget().pack(fill="both", expand=True, padx=8, pady=8)

    # ── CONFIRM SHOW / HIDE (simple toggle — NO 'before' keyword) ─────────────
    def _show_confirm(self):
        """Make the confirm frame visible by re-packing it."""
        self._confirm_frame.pack(fill="x", padx=12, pady=4)

    def _hide_confirm(self):
        """Hide the confirm frame without destroying it."""
        self._confirm_frame.pack_forget()

    # ── STEP FLOW ──────────────────────────────────────────────────────────────
    def _populate_seq_table(self):
        for item in self._results_tree.get_children():
            self._results_tree.delete(item)
        self._tree_ids = []
        for i,(base,tgt,lbl) in enumerate(CAL_SEQUENCE):
            iid = self._results_tree.insert("","end",
                values=(i+1, GAS_NAMES.get(base,"?"),
                        GAS_NAMES.get(tgt,"?"), "—", "pending"),
                tags=("pending",))
            self._tree_ids.append(iid)

    def _mark_row(self, idx, tag, slope_txt="—", status="pending"):
        if idx < 0 or idx >= len(self._tree_ids): return
        iid  = self._tree_ids[idx]
        vals = list(self._results_tree.item(iid,"values"))
        vals[3] = slope_txt; vals[4] = status
        self._results_tree.item(iid, values=vals, tags=(tag,))

    def _start_cal(self):
        if not self._streaming:
            messagebox.showwarning("No Signal",
                "Open a live log file or start the simulator first.",
                parent=self); return
        self._measured  = []; self._step_idx = -1
        self._populate_seq_table()
        self._start_btn.config(state="disabled")
        self._skip_btn.config(state="normal")
        self._finish_btn.config(state="normal")
        self._wiz_state = "running"
        self._advance_step()

    def _advance_step(self):
        self._step_idx += 1
        if self._step_idx >= len(CAL_SEQUENCE):
            self._finish_cal(); return
        base, tgt, lbl = CAL_SEQUENCE[self._step_idx]
        for i in range(len(self._tree_ids)):
            if   i == self._step_idx: self._mark_row(i,"active","—","● ACTIVE")
            elif i  > self._step_idx: self._mark_row(i,"pending","—","pending")
        self._inst_lbl.config(
            text=f"Step {self._step_idx+1} / {len(CAL_SEQUENCE)}:  {lbl}\n"
                 f"Expose sensor to  {GAS_NAMES.get(tgt,'?')}\n"
                 f"Waiting for gas onset…",
            fg=YELLOW)
        self._cap_str.set("⏳  Waiting for gas onset…")
        self._max_slope_str.set("—")
        self._update_progress(self._step_idx)
        self._hide_confirm()
        self._wiz_state = "running"
        self._capturer = SlopeCapture(
            on_done=self._step_captured,
            on_sample=self._cap_sample_update)

    def _cap_sample_update(self, dvdt, state, count):
        self._live_slope_str.set(f"{dvdt:.2f}")
        if state == "CAPTURING" and self._capturer:
            self._cap_str.set(f"🔴  CAPTURING  {count} / {SLOPE_WIN}")
            self._max_slope_str.set(f"{self._capturer.max_slope:.3f}")

    def _step_captured(self, max_slope):
        """Capture complete — pause and show Accept / Redo buttons."""
        base, tgt, lbl = CAL_SEQUENCE[self._step_idx]
        self._mark_row(self._step_idx, "confirm", f"{max_slope:.3f}", "⚠  CONFIRM?")
        self._inst_lbl.config(
            text=f"Step {self._step_idx+1}  —  {lbl}\n"
                 f"Max dV/dt captured:  {max_slope:.3f} mV/s\n\n"
                 f"✅  Accept to save and continue.\n"
                 f"🔁  Redo to repeat this step.",
            fg=ORANGE)
        self._cap_str.set(f"⚠  Awaiting confirmation  ({max_slope:.3f} mV/s)")
        self._max_slope_str.set(f"{max_slope:.3f}")
        self._wiz_state = "awaiting_confirm"
        self._show_confirm()   # ← clean pack, no 'before' issue

    def _accept_step(self):
        if self._wiz_state != "awaiting_confirm": return
        max_slope = self._capturer.max_slope
        base, tgt, lbl = CAL_SEQUENCE[self._step_idx]
        self._measured.append((base, tgt, max_slope))
        self._mark_row(self._step_idx, "done", f"{max_slope:.3f}", "✓  DONE")
        self._hide_confirm()
        self._inst_lbl.config(
            text=f"✓  Step {self._step_idx+1} accepted  ({max_slope:.3f} mV/s)\n"
                 f"Advancing to next step…",
            fg=GREEN)
        self._wiz_state = "running"
        self.after(700, self._advance_step)

    def _redo_step(self):
        if self._wiz_state != "awaiting_confirm": return
        base, tgt, lbl = CAL_SEQUENCE[self._step_idx]
        self._mark_row(self._step_idx, "active", "—", "● REDO")
        self._hide_confirm()
        self._inst_lbl.config(
            text=f"🔁  Redo — Step {self._step_idx+1}:  {lbl}\n"
                 f"Return sensor to {GAS_NAMES.get(base,'baseline')},\n"
                 f"then re-expose to {GAS_NAMES.get(tgt,'?')}.\n"
                 f"Waiting for onset…",
            fg=YELLOW)
        self._cap_str.set("⏳  Waiting for new onset…")
        self._max_slope_str.set("—")
        self._wiz_state = "running"
        self._capturer.reset()

    def _skip_step(self):
        if self._step_idx < 0 or self._step_idx >= len(CAL_SEQUENCE): return
        self._hide_confirm()
        self._mark_row(self._step_idx, "skipped", "—", "SKIPPED")
        self._capturer = None; self._wiz_state = "running"
        self.after(200, self._advance_step)

    def _update_progress(self, done):
        total = len(CAL_SEQUENCE); frac = done/total if total else 0
        self._prog_str.set(f"{done} / {total}")
        self._prog_cv.coords(self._prog_bar, 0,0, int(440*frac), 8)

    def _finish_cal(self):
        if not self._measured:
            messagebox.showwarning("No Data","No steps completed.", parent=self)
            self._start_btn.config(state="normal")
            self._skip_btn.config(state="disabled")
            self._finish_btn.config(state="disabled")
            return
        air_bl = self._capturer.air_baseline if self._capturer else 28.0
        CAL_MGR.build_from_wizard(self._measured, air_bl)
        self._hdr_badge.config(text="● CALIBRATED", fg=GREEN)
        self._update_progress(len(CAL_SEQUENCE))
        self._inst_lbl.config(
            text=f"✅  Calibration complete!\n"
                 f"   {len(self._measured)} steps accepted.\n"
                 f"   Curves saved → {CAL_AUTOSAVE}\n"
                 f"   Detection tab is now UNLOCKED.",
            fg=GREEN)
        self._cap_str.set("")
        self._hide_confirm()
        self._start_btn.config(state="normal")
        self._skip_btn.config(state="disabled")
        self._finish_btn.config(state="disabled")
        self._stop_graph_btn.config(state="normal")
        self._wiz_state = "done"
        if self._on_complete: self._on_complete()

    def _stop_graph(self):
        self._stop_stream()
        self._stop_graph_btn.config(state="disabled")
        self._cap_str.set("📊  Live graph stopped — data preserved.")

    def _reset_cal(self):
        if not messagebox.askyesno("Reset","Discard all calibration data?",parent=self):
            return
        CAL_MGR.reset_to_factory()
        self._measured=[]; self._step_idx=-1; self._capturer=None
        self._wiz_state="idle"
        self._hdr_badge.config(text="● NOT CALIBRATED", fg=RED)
        self._populate_seq_table()
        self._inst_lbl.config(text="Press START to begin.", fg=TEXT)
        self._cap_str.set(""); self._max_slope_str.set("—"); self._live_slope_str.set("—")
        self._prog_str.set("0 / 0"); self._prog_cv.coords(self._prog_bar,0,0,0,8)
        self._start_btn.config(state="normal")
        self._skip_btn.config(state="disabled")
        self._finish_btn.config(state="disabled")
        self._stop_graph_btn.config(state="disabled")
        self._hide_confirm()
        if self._on_reset: self._on_reset()

    # ── DATA STREAMING ────────────────────────────────────────────────────────
    def push_sample(self, v):
        self._t_elapsed += DT
        self._v_hist.append(v)
        self._t_hist.append(self._t_elapsed)
        dv = (v - self._v_hist[-2]) / DT if len(self._v_hist) >= 2 else 0.0
        self._dvdt_hist.append(dv)
        if (self._capturer and
                self._capturer.state != "DONE" and
                self._wiz_state == "running"):
            self._capturer.push(v)
        self._chart_dirty = True

    def _scheduled_chart_draw(self):
        if self._chart_dirty:
            self._chart_dirty = False
            t = list(self._t_hist); v = list(self._v_hist); dv = list(self._dvdt_hist)
            if t:
                self._ln_v.set_data(t, v); self._ln_dvdt.set_data(t, dv)
                for ax, vals in [(self._ax_v, v), (self._ax_dvdt, dv)]:
                    ax.set_xlim(t[0], max(t[-1], t[0]+5))
                    rng = max(vals)-min(vals) if len(vals)>1 else 1
                    pad = max(rng*0.15, 0.5)
                    ax.set_ylim(min(vals)-pad, max(vals)+pad)
                self._canvas_cal.draw_idle()
        self._chart_job = self.after(self.CHART_INTERVAL_MS, self._scheduled_chart_draw)

    def _open_live(self):
        path = filedialog.askopenfilename(
            title="Open Smart Probe log for calibration",
            filetypes=[("Log","*.log *.txt"),("All","*.*")])
        if not path: return
        self._stop_stream()
        self._tailer = LogTailer(path); self._tailer.start()
        self._streaming = True
        self._tick_live(); self._scheduled_chart_draw()

    def _tick_live(self):
        if not self._streaming or not self._tailer: return
        for v in self._tailer.get_new(): self.push_sample(v)
        self._tick_job = self.after(60, self._tick_live)

    def _open_sim(self):
        sim = Simulator()
        steps = [(0,30)]
        for _, tgt, _ in CAL_SEQUENCE:
            steps.append((tgt,90)); steps.append((0,60))
        _, v_arr, _ = sim.generate(steps, baseline_mv=28.0, noise_std=0.05)
        self._streaming=True; self._sim_data=v_arr; self._sim_idx=0
        self._scheduled_chart_draw(); self._tick_sim()

    def _tick_sim(self):
        if not self._streaming or not hasattr(self,"_sim_data"): return
        if self._sim_idx >= len(self._sim_data):
            self._streaming=False; return
        self.push_sample(self._sim_data[self._sim_idx])
        self._sim_idx += 1
        self._tick_job = self.after(20, self._tick_sim)

    def _stop_stream(self):
        if self._tick_job:  self.after_cancel(self._tick_job);  self._tick_job=None
        if self._chart_job: self.after_cancel(self._chart_job); self._chart_job=None
        if self._tailer:    self._tailer.stop(); self._tailer=None
        self._streaming=False

    def _load_saved(self):
        if not CAL_MGR.is_calibrated:
            messagebox.showinfo("No Saved Calibration",
                f"No saved calibration found.\n({CAL_AUTOSAVE})",parent=self); return
        self._hdr_badge.config(text="● CALIBRATED (loaded)", fg=GREEN)
        self._populate_seq_table()
        self._inst_lbl.config(
            text=f"✅  Saved calibration loaded.\nDetection tab UNLOCKED.", fg=GREEN)
        self._stop_graph_btn.config(state="normal")
        if self._on_complete: self._on_complete()

    def _export_csv(self):
        path = filedialog.asksaveasfilename(
            defaultextension=".csv", filetypes=[("CSV","*.csv")],
            initialfile="calibration_v10.csv", parent=self)
        if not path: return
        CAL_MGR.export_csv(path)
        messagebox.showinfo("Exported", f"Saved to:\n{path}", parent=self)

    def _card(self, parent, label):
        outer = tk.Frame(parent, bg=BORDER, padx=1, pady=1)
        inner = tk.Frame(outer, bg=SURFACE)
        inner.pack(fill="both", expand=True)
        tk.Label(inner, text=f"  {label}",
                 font=("Courier New",8,"bold"), fg=MUTED,
                 bg=SURFACE, anchor="w", pady=5).pack(fill="x")
        tk.Frame(inner, bg=BORDER, height=1).pack(fill="x")
        outer.pack(fill="both", expand=False)
        return inner

    def on_destroy(self):
        self._stop_stream()


