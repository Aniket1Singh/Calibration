# ── hybrid math ───────────────────────────────────────────────────────────────
def piecewise_interp_2D(current_state, S):
    curve = CALIBRATION_CURVES.get(current_state, [])
    if not curve: return float(current_state)
    slopes = [p[0] for p in curve];  ppms = [p[1] for p in curve]
    if S > slopes[-1]:
        return ppms[-1] * np.exp(0.01 * (S - slopes[-1]))
    return float(np.interp(S, slopes, ppms))

def predict_discrete_state(current_state, S, margin=0.15):
    for ts, tp in CALIBRATION_CURVES.get(current_state, []):
        if ts == 0.0: continue
        if ts*(1-margin) <= S <= ts*(1+margin):
            return tp
    return None

def final_output(current_state, S):
    C_smooth   = piecewise_interp_2D(current_state, S)
    C_discrete = predict_discrete_state(current_state, S)
    if C_discrete is not None:
        return round(0.7*C_discrete + 0.3*C_smooth, 1)
    return round(C_smooth, 1)

def get_base_state(ppm_val):
    for s in sorted(CALIBRATION_CURVES.keys(), reverse=True):
        if ppm_val >= s * 0.8: return s
    return 0

def _interp_label(ppm):
    if ppm < 10:   return "Air / ambient"
    if ppm < 9000: return f"~{ppm:.0f} ppm H₂"
    return f"~{ppm/10000:.2f}% H₂"

def ppm_color(ppm):
    if ppm <   10: return GREEN
    if ppm <  300: return CYAN
    if ppm < 1500: return YELLOW
    if ppm < 8000: return ORANGE
    return RED

# ── calibration manager ───────────────────────────────────────────────────────
class CalibrationManager:
    def __init__(self):
        self._calibrated      = False
        self._cal_baseline_mv = 28.0
        self._try_load()

    @property
    def is_calibrated(self): return self._calibrated
    @property
    def cal_baseline_mv(self): return self._cal_baseline_mv

    def build_from_wizard(self, measured_points, air_baseline_mv):
        global CALIBRATION_CURVES
        curves = copy.deepcopy(FACTORY_CURVES)
        for base_ppm, tgt_ppm, slope in measured_points:
            curve = curves.get(base_ppm, [(0.0, base_ppm)])
            curve = [p for p in curve if p[1] != tgt_ppm or p[0] == 0.0]
            curve.append((round(slope, 4), tgt_ppm))
            curve.sort(key=lambda p: p[0])
            curves[base_ppm] = curve
        CALIBRATION_CURVES = curves
        self._calibrated      = True
        self._cal_baseline_mv = air_baseline_mv
        self._autosave()

    def update_single_point(self, base_ppm, tgt_ppm, new_slope):
        curve   = CALIBRATION_CURVES.get(base_ppm, [])
        updated = [(s, p) if p != tgt_ppm else (round(new_slope, 4), p) for s, p in curve]
        updated.sort(key=lambda p: p[0])
        CALIBRATION_CURVES[base_ppm] = updated
        self._autosave()

    def reset_to_factory(self):
        global CALIBRATION_CURVES
        CALIBRATION_CURVES = copy.deepcopy(FACTORY_CURVES)
        self._calibrated = False
        if os.path.exists(CAL_AUTOSAVE): os.remove(CAL_AUTOSAVE)

    def _autosave(self):
        try:
            data = {"curves": {str(k): v for k, v in CALIBRATION_CURVES.items()},
                    "air_baseline": self._cal_baseline_mv,
                    "calibrated":   self._calibrated}
            with open(CAL_AUTOSAVE, "w") as f: json.dump(data, f, indent=2)
        except Exception: pass

    def _try_load(self):
        global CALIBRATION_CURVES
        if not os.path.exists(CAL_AUTOSAVE): return
        try:
            with open(CAL_AUTOSAVE) as f: raw = json.load(f)
            CALIBRATION_CURVES = {int(k): [tuple(p) for p in v]
                                  for k, v in raw["curves"].items()}
            self._cal_baseline_mv = raw.get("air_baseline", 28.0)
            self._calibrated      = raw.get("calibrated", False)
        except Exception: pass

    def export_csv(self, path):
        with open(path, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(["baseline_ppm","target_ppm","slope_mVs","source"])
            for state, curve in sorted(CALIBRATION_CURVES.items()):
                fslopes = {p[0] for p in FACTORY_CURVES.get(state, [])}
                for slope, ppm in curve:
                    w.writerow([state, ppm, slope,
                                "factory" if slope in fslopes else "user"])

CAL_MGR = CalibrationManager()

# ── slope capture ─────────────────────────────────────────────────────────────
class SlopeCapture:
    def __init__(self, on_done, on_sample=None):
        self._on_done    = on_done
        self._on_sample  = on_sample
        self._state      = "WAITING"
        self._diff_buf   = collections.deque(maxlen=TRIG_WIN)
        self._slow_buf   = collections.deque(maxlen=SLOW_CONSEC)
        self._prev_v     = None
        self._count      = 0
        self._max_slope  = 0.0
        self._baseline_v = collections.deque(maxlen=WARMUP_SAMP)
        self._warmup_done= False
        self._air_baseline = 28.0

    @property
    def state(self): return self._state
    @property
    def max_slope(self): return self._max_slope
    @property
    def air_baseline(self): return self._air_baseline

    def push(self, v):
        if self._state == "DONE": return
        if not self._warmup_done:
            self._baseline_v.append(v)
            if len(self._baseline_v) >= WARMUP_SAMP:
                self._air_baseline = float(np.mean(self._baseline_v))
                self._warmup_done  = True
            if self._on_sample: self._on_sample(0.0, "WARMUP", 0)
            return
        diff = (v - self._prev_v) if self._prev_v is not None else 0.0
        self._prev_v = v
        self._diff_buf.append(diff)
        self._slow_buf.append(diff)
        dvdt = 0.0
        if len(self._diff_buf) == TRIG_WIN:
            dvdt = (sum(self._diff_buf) / TRIG_WIN) / DT
        if self._state == "WAITING":
            fast = dvdt > (ONSET_THRESH / DT)
            slow = (len(self._slow_buf) == SLOW_CONSEC and
                    all(d > SLOW_THRESH for d in self._slow_buf))
            if fast or slow:
                self._state = "CAPTURING"
                self._count = 0
                self._max_slope = dvdt
        elif self._state == "CAPTURING":
            self._count += 1
            if self._count <= SLOPE_WIN:
                self._max_slope = max(self._max_slope, dvdt)
            if self._count >= SLOPE_WIN:
                self._state = "DONE"
                self._on_done(self._max_slope)
                return
        if self._on_sample: self._on_sample(dvdt, self._state, self._count)

    def reset(self):
        self._state     = "WAITING"
        self._count     = 0
        self._max_slope = 0.0
        self._diff_buf.clear()
        self._slow_buf.clear()
        self._prev_v    = None

# ── detector ──────────────────────────────────────────────────────────────────
class Detector:
    def __init__(self, dt=DT, baseline_ppm=0):
        self.dt = dt; self.baseline_ppm = baseline_ppm
        self.events = []; self._reset_all()

    def set_baseline_ppm(self, ppm): self.baseline_ppm = ppm
    def set_initial_baseline(self, mv): self.baseline_mv = mv

    def _reset_all(self):
        self.state            = "WARMUP"; self.cur_ppm = 0
        self.display_ppm      = 0.0
        self.baseline_mv      = CAL_MGR.cal_baseline_mv
        self._v_buf           = collections.deque(maxlen=SLOPE_WIN+1)
        self._diff_buf        = collections.deque(maxlen=TRIG_WIN)
        self._slow_buf        = collections.deque(maxlen=SLOW_CONSEC)
        self._measuring_count = 0; self._max_slope = 0.0
        self._flat_count      = 0
        self._locked_bl       = CAL_MGR.cal_baseline_mv
        self._timer_cnt       = 0; self._prev_v = None
        self._cur_label       = "Air / ambient"
        self._cur_rates       = {"10pt":0.0,"20pt":0.0,"50pt":0.0,"peak":0.0}
        self._cur_regime      = "—"; self._cur_regime_col = SUB
        self._cur_delta_v     = 0.0; self._discrete_hit = False
        self._pending_ev      = None
        self._warmup_buf      = collections.deque(maxlen=WARMUP_SAMP)
        self._warmup_done     = False

    def reset(self): self._reset_all()

    def push(self, v_mv):
        self._v_buf.append(v_mv)
        if self._prev_v is None: self._prev_v = v_mv
        diff = v_mv - self._prev_v; self._prev_v = v_mv
        self._diff_buf.append(diff); self._slow_buf.append(diff)
        ev = None; dvdt_mVs = 0.0
        if len(self._diff_buf) == TRIG_WIN:
            dvdt_mVs = (sum(self._diff_buf) / TRIG_WIN) / self.dt

        if self.state == "WARMUP":
            self._warmup_buf.append(v_mv)
            if len(self._warmup_buf) >= WARMUP_SAMP and not self._warmup_done:
                self.baseline_mv  = (CAL_MGR.cal_baseline_mv if CAL_MGR.is_calibrated
                                     else float(np.mean(self._warmup_buf)))
                self._locked_bl   = self.baseline_mv
                self._warmup_done = True; self.state = "AIR"

        elif self.state == "AIR":
            self.baseline_mv = self.baseline_mv*0.99 + v_mv*0.01
            fast = dvdt_mVs > (ONSET_THRESH / self.dt)
            slow = (len(self._slow_buf) == SLOW_CONSEC and
                    all(d > SLOW_THRESH for d in self._slow_buf))
            if fast or slow:
                self._locked_bl = self.baseline_mv; self._timer_cnt = 0
                self._measuring_count = 0; self._max_slope = dvdt_mVs
                self.state = "MEASURING"
                ev = self._make_ev("ONSET_DETECTED", 0, 0.0,
                                   f"{'fast' if fast else 'slow'} onset")

        elif self.state == "MEASURING":
            self._measuring_count += 1; self._timer_cnt += 1
            if self._measuring_count <= SLOPE_WIN:
                self._max_slope = max(self._max_slope, dvdt_mVs)
            if self._measuring_count >= SLOPE_WIN:
                self.display_ppm = final_output(self.cur_ppm, self._max_slope)
                self.cur_ppm     = get_base_state(self.display_ppm)
                self._cur_label  = _interp_label(self.display_ppm)
                self._discrete_hit = predict_discrete_state(
                    get_base_state(self.display_ppm), self._max_slope) is not None
                self._cur_delta_v = v_mv - self._locked_bl
                self._cur_rates   = {k: self._max_slope for k in ("10pt","20pt","50pt","peak")}
                self._cur_regime  = ("HIGH"   if self._max_slope >= 40 else
                                     "MEDIUM" if self._max_slope >= 10 else "LOW")
                self._cur_regime_col = (GREEN  if self._cur_regime=="HIGH" else
                                        YELLOW if self._cur_regime=="MEDIUM" else RED)
                self.state = "GAS_ON"; self._flat_count = 0
                ev = self._make_ev("GAS_DETECTED", self.display_ppm, self._cur_delta_v,
                    f"{self._cur_label}  [slope={self._max_slope:.2f} mV/s  "
                    f"{'SNAP' if self._discrete_hit else 'INTERP'}]")

        elif self.state == "GAS_ON":
            if dvdt_mVs > (ONSET_THRESH*10)/self.dt:
                self._measuring_count = 0; self._max_slope = dvdt_mVs
                self._timer_cnt = 0; self.state = "MEASURING"
            elif dvdt_mVs < (FALL_THRESH/self.dt):
                self.display_ppm = 0.0; self.cur_ppm = 0
                self._cur_label  = "Air / Recovering…"; self._flat_count = 0
                self.state = "FALLING"
                ev = self._make_ev("RECOVERY_STARTED", 0, 0.0, "falling")

        elif self.state in ("FALLING","SETTLING"):
            if dvdt_mVs > 5.0:
                self._measuring_count = 0; self._max_slope = dvdt_mVs
                self._timer_cnt = 0; self.state = "MEASURING"
            else:
                if abs(diff) < FLAT_THRESH:
                    self._flat_count += 1; self.state = "SETTLING"
                    if self._flat_count >= FLAT_CONSEC:
                        self.baseline_mv = float(np.mean(self._v_buf))
                        self._locked_bl  = self.baseline_mv
                        self.state = "AIR"; self._flat_count = 0
                        self._slow_buf.clear()
                        ev = self._make_ev("BASELINE_UPDATED", 0, 0.0,
                            f"new baseline: {self.baseline_mv:.2f} mV")
                else:
                    self._flat_count = 0; self.state = "FALLING"

        if ev: self.events.append(ev)
        return self._build_result(v_mv, dvdt_mVs)

    def _build_result(self, v_mv, dvdt_mVs):
        ppm = self.display_ppm
        return {"state":self.state,"v":v_mv,"diff_mvs":dvdt_mVs,
                "baseline":self.baseline_mv,"locked_bl":self._locked_bl,
                "timer":self._timer_cnt,"delta_v":self._cur_delta_v,
                "ppm":ppm,"ppm_dv":ppm,"ppm_mm":ppm,
                "label":self._cur_label,"in_band":self._discrete_hit,
                "regime":self._cur_regime,"regime_col":self._cur_regime_col,
                "rates":self._cur_rates,"mm_preds":{},
                "event":self._consume_pending_ev()}

    def _consume_pending_ev(self):
        ev = self._pending_ev; self._pending_ev = None; return ev

    def _make_ev(self, kind, ppm, delta_v, note):
        ev = {"kind":kind,"ppm":ppm,"delta_v":delta_v,"note":note,
              "baseline":self._locked_bl}
        self._pending_ev = ev; return ev

# ── simulator ─────────────────────────────────────────────────────────────────
SIM_DV48    = {0:0,100:8.0,1000:102.0,5000:300.0,10000:347.0,20000:650.0}
SIM_PLATEAU = {0:0,100:30.0,1000:240.0,5000:420.0,10000:545.0,20000:1080.0}
SIM_TAUR    = {0:1,100:11.7,1000:11.3,5000:10.4,10000:9.6,20000:8.7}
SIM_TAUF    = {0:1,100:5.6,1000:4.3,5000:3.5,10000:3.0,20000:2.6}
PPM_KEYS_SIM = sorted(SIM_DV48.keys())

def _sim_interp(d, ppm):
    return float(np.interp(ppm,
        np.array(PPM_KEYS_SIM,dtype=float),
        np.array([d[k] for k in PPM_KEYS_SIM],dtype=float)))

class Simulator:
    def generate(self, steps, baseline_mv=28.0, noise_std=0.08, dt=DT):
        t_list, v_list, lbl_list = [], [], []; t=0.0; v=baseline_mv
        for gas_ppm, duration_s in steps:
            n = max(1, int(duration_s/dt))
            if gas_ppm > 0:
                target_v   = baseline_mv + _sim_interp(SIM_PLATEAU, gas_ppm)
                target_v48 = baseline_mv + _sim_interp(SIM_DV48, gas_ppm)
                ramp = (target_v48-v)/TIMER_SAMP
                tau_r = _sim_interp(SIM_TAUR, gas_ppm)
                for i in range(n):
                    v_t = (v+ramp*(i+1) if i<TIMER_SAMP
                           else target_v48+(target_v-target_v48)*(1-math.exp(-(i-TIMER_SAMP)*dt/tau_r)))
                    t_list.append(round(t,4)); v_list.append(v_t+np.random.normal(0,noise_std))
                    lbl_list.append(f"{gas_ppm}ppm"); t+=dt
                v = target_v
            else:
                tau_f=_sim_interp(SIM_TAUF,max(gas_ppm,100)); sd=v-baseline_mv
                for i in range(n):
                    t_list.append(round(t,4))
                    v_list.append(baseline_mv+sd*math.exp(-i*dt/tau_f)+np.random.normal(0,noise_std))
                    lbl_list.append("air"); t+=dt
                v = baseline_mv
        return np.array(t_list), np.array(v_list), lbl_list

# ── log tailer ────────────────────────────────────────────────────────────────
DATA_RE = re.compile(r'^\s*[+-]?\d+\.\d+\s+([+-]\d+\.\d+)')

class LogTailer:
    def __init__(self, path):
        self.path=path; self._buf=collections.deque()
        self._stop=threading.Event(); self._lock=threading.Lock()
        self._th=threading.Thread(target=self._run,daemon=True)
    def start(self): self._th.start()
    def stop(self):  self._stop.set()
    def _run(self):
        try: f=open(self.path,"r",errors="replace"); f.seek(0,2)
        except: return
        rem=""
        while not self._stop.is_set():
            chunk=f.read(4096)
            if chunk:
                rem+=chunk; lines=rem.split("\n"); rem=lines[-1]
                for line in lines[:-1]:
                    m=DATA_RE.match(line)
                    if m:
                        try:
                            with self._lock: self._buf.append(float(m.group(1)))
                        except: pass
            else: time.sleep(0.02)
        f.close()
    def get_new(self):
        with self._lock: d=list(self._buf); self._buf.clear(); return d


