                      bg=bg, fg=fg, relief="flat", cursor="hand2",
                      padx=8, pady=4, command=cmd).pack(side="left", padx=4)
        tk.Label(tb, text="Green=user  Grey=factory  ·  Edit slopes/Δemf → Refit",
                 font=("Courier New",7), fg=MUTED, bg=PANEL).pack(side="right", padx=12)

        nb = ttk.Notebook(self); nb.pack(fill="both", expand=True)

        # Tab A: slope vs ppm
        tab_a = tk.Frame(nb, bg=BG); nb.add(tab_a, text="Slope vs ppm")
        self._fig_slope = Figure(facecolor=BG)
        self._canvas_slope = FigureCanvasTkAgg(self._fig_slope, master=tab_a)
        self._canvas_slope.get_tk_widget().pack(side="left",fill="both",expand=True)
        right_a = tk.Frame(tab_a, bg=PANEL, width=330)
        right_a.pack(side="right",fill="y"); right_a.pack_propagate(False)
        self._build_edit_panel(right_a)

        # Tab B: slope vs delta_emf  (new 2D scatter)
        tab_b = tk.Frame(nb, bg=BG); nb.add(tab_b, text="Slope vs Δ EMF (2D)")
        self._fig_2d = Figure(facecolor=BG)
        self._canvas_2d = FigureCanvasTkAgg(self._fig_2d, master=tab_b)
        self._canvas_2d.get_tk_widget().pack(fill="both",expand=True)

    def _build_edit_panel(self, parent):
        tk.Label(parent, text="  Edit Calibration Values",
                 font=("Courier New",9,"bold"), fg=TEAL, bg=PANEL, pady=8).pack(fill="x")
        tk.Frame(parent, bg=BORDER, height=1).pack(fill="x")
        cvs=tk.Canvas(parent, bg=PANEL, highlightthickness=0)
        sb=ttk.Scrollbar(parent, orient="vertical", command=cvs.yview)
        self._edit_inner=tk.Frame(cvs, bg=PANEL)
        self._edit_inner.bind("<Configure>",
            lambda e: cvs.configure(scrollregion=cvs.bbox("all")))
        cvs.create_window((0,0), window=self._edit_inner, anchor="nw")
        cvs.configure(yscrollcommand=sb.set)
        sb.pack(side="right",fill="y"); cvs.pack(fill="both",expand=True,padx=4,pady=4)
        tk.Button(parent, text="✅  Apply & Refit",
                  font=("Courier New",9,"bold"), bg=GREEN, fg="#0a0c0f",
                  relief="flat", cursor="hand2", pady=8,
                  command=self._apply_edits).pack(fill="x", padx=8, pady=6)
        tk.Button(parent, text="🏭  Restore Factory",
                  font=("Courier New",8), bg=RED, fg=TEXT,
                  relief="flat", cursor="hand2", pady=6,
                  command=self._restore_factory).pack(fill="x", padx=8, pady=(0,6))

    def _rebuild_edit_table(self):
        for w in self._edit_inner.winfo_children(): w.destroy()
        self._entry_vars.clear()
        fact_map = {(b,p[2]):(p[0],p[1]) for b,c in FACTORY_CURVES.items() for p in c}
        for base in sorted(CALIBRATION_CURVES.keys()):
            hdr=tk.Frame(self._edit_inner, bg=DIM); hdr.pack(fill="x",pady=(8,2))
            tk.Label(hdr, text=f"  Baseline: {GAS_NAMES.get(base,str(base))}",
                     font=("Courier New",8,"bold"), fg=TEAL, bg=DIM, pady=4).pack(side="left")
            for slope,delta_emf,ppm in CALIBRATION_CURVES[base]:
                if slope==0.0: continue
                fact  = fact_map.get((base,ppm))
                is_u  = fact is None or fact[0] != slope
                row   = tk.Frame(self._edit_inner, bg=SURFACE2); row.pack(fill="x",pady=1)
                tk.Label(row, text=f"→{PPM_LABELS.get(ppm,str(ppm))}",
                         font=("Courier New",8), fg=MUTED, bg=SURFACE2,
                         width=7, anchor="w", padx=4).pack(side="left")
                sv=tk.StringVar(value=f"{slope:.4f}")
                ev_k=tk.StringVar(value=f"{delta_emf:.2f}")
                self._entry_vars[(base,ppm,"slope")]    = sv
                self._entry_vars[(base,ppm,"delta_emf")] = ev_k
                for v2,w2,lbl2 in [(sv,8,"mV/s"),(ev_k,7,"ΔmV")]:
                    e=tk.Entry(row, textvariable=v2, width=w2,
                               bg=DIM if is_u else BORDER,
                               fg=GREEN if is_u else TEXT,
                               insertbackground=TEXT, relief="flat",
                               font=("Courier New",9))
                    e.pack(side="left",padx=2,pady=3)
                    tk.Label(row,text=lbl2,font=("Courier New",7),
                             fg=MUTED,bg=SURFACE2,padx=2).pack(side="left")
                tk.Label(row, text="★" if is_u else "·",
                         font=("Courier New",8), fg=GREEN if is_u else MUTED,
                         bg=SURFACE2, padx=3).pack(side="right")

    def _apply_edits(self):
        done=set()
        for (base,ppm,feat), var in self._entry_vars.items():
            key=(base,ppm)
            if key not in done:
                done.add(key)
                sv = self._entry_vars.get((base,ppm,"slope"))
                ev = self._entry_vars.get((base,ppm,"delta_emf"))
                try:
                    ns = float(sv.get()) if sv else 0.0
                    ne = float(ev.get()) if ev else 0.0
                    CAL_MGR.update_single_point(base, ppm, ns, ne)
                except ValueError:
                    messagebox.showerror("Invalid","Bad value."); return
        CAL_MGR._autosave(); self.refresh()

    def _restore_factory(self):
        if not messagebox.askyesno("Restore factory","Reset all slopes to factory defaults?"): return
        global CALIBRATION_CURVES
        CALIBRATION_CURVES=copy.deepcopy(FACTORY_CURVES)
        CAL_MGR._autosave(); self.refresh()

    def refresh(self):
        self._draw_slope_curves()
        self._draw_2d_scatter()
        self._rebuild_edit_table()

    def _draw_slope_curves(self):
        self._fig_slope.clear()
        states=sorted(CALIBRATION_CURVES.keys()); n=len(states)
        cols_n=3; rows_n=math.ceil(n/cols_n)
        fit_type=self._fit_type.get()
        fact_map={(b,p[2]):p[0] for b,c in FACTORY_CURVES.items() for p in c}
        for idx,base in enumerate(states):
            ax=self._fig_slope.add_subplot(rows_n,cols_n,idx+1)
            ax.set_facecolor(SURFACE)
            for sp in ax.spines.values(): sp.set_color(BORDER)
            ax.tick_params(colors=MUTED, labelsize=6)
            ax.set_title(f"Base: {GAS_NAMES.get(base,str(base))}",
                         fontsize=7,color=MUTED,fontfamily="monospace")
            ax.set_xlabel("ppm",fontsize=6,color=MUTED)
            ax.set_ylabel("slope (mV/s)",fontsize=6,color=MUTED)
            ax.grid(True,color=BORDER,lw=0.4,ls="--",alpha=0.5)
            curve=CALIBRATION_CURVES[base]
            slopes=[p[0] for p in curve if p[0]>0]
            ppms  =[p[2] for p in curve if p[0]>0]
            if not slopes: continue
            for s,p in zip(slopes,ppms):
                is_u=fact_map.get((base,p),None)!=s
                ax.scatter(p,s,color=GREEN if is_u else MUTED,
                           s=40,zorder=5,edgecolors=SURFACE,linewidths=1)
                ax.annotate(PPM_LABELS.get(p,str(p)),xy=(p,s),xytext=(4,3),
                            textcoords="offset points",fontsize=5,color=MUTED)
            p_arr=np.array(ppms,dtype=float); s_arr=np.array(slopes,dtype=float)
            xfit=np.linspace(p_arr.min(),p_arr.max()*1.05,200)
            try:
                if fit_type=="linear-interp":
                    ax.plot(xfit,np.interp(xfit,p_arr,s_arr),color=ACCENT,lw=1.2)
                elif fit_type=="power-law" and len(p_arr)>=2:
                    c=np.polyfit(np.log10(np.clip(p_arr,1,None)),
                                 np.log10(np.clip(s_arr,0.01,None)),1)
                    ax.plot(xfit,10**c[1]*xfit**c[0],color=PURPLE,lw=1.2,
                            label=f"b={c[0]:.2f}")
                    ax.legend(facecolor=SURFACE,labelcolor=TEXT,fontsize=5)
                elif fit_type=="michaelis-menten" and len(p_arr)>=2:
                    def mm(x,Vm,Km): return Vm*x/(Km+x)
                    popt,_=curve_fit(mm,p_arr,s_arr,
                                     p0=[s_arr.max()*1.5,p_arr.mean()],
                                     maxfev=5000,bounds=([0,0],[1e6,1e8]))
                    ax.plot(xfit,mm(xfit,*popt),color=TEAL,lw=1.2,
                            label=f"Vm={popt[0]:.0f}")
                    ax.legend(facecolor=SURFACE,labelcolor=TEXT,fontsize=5)
            except Exception: pass
        self._fig_slope.set_facecolor(BG)
        self._fig_slope.subplots_adjust(hspace=0.55,wspace=0.38,
                                        left=0.08,right=0.97,top=0.94,bottom=0.08)
        self._canvas_slope.draw_idle()

    def _draw_2d_scatter(self):
        self._fig_2d.clear()
        ax=self._fig_2d.add_subplot(111)
        ax.set_facecolor(SURFACE)
        for sp in ax.spines.values(): sp.set_color(BORDER)
        ax.tick_params(colors=MUTED,labelsize=8)
        ax.set_title("2D Feature Space: slope vs Δ EMF  (each point = one transition)",
                     fontsize=9,color=MUTED,fontfamily="monospace")
        ax.set_xlabel("Δ EMF — 20-pt window (mV)",fontsize=8,color=MUTED)
        ax.set_ylabel("Mean slope — 20-pt (mV/s)",fontsize=8,color=MUTED)
        ax.grid(True,color=BORDER,lw=0.5,ls="--",alpha=0.5)

        COLORS = [ACCENT,GREEN,TEAL,YELLOW,ORANGE,PURPLE,RED,CYAN]
        fact_map={(b,p[2]):(p[0],p[1]) for b,c in FACTORY_CURVES.items() for p in c}

        handles=[]
        for bi,base in enumerate(sorted(CALIBRATION_CURVES.keys())):
            col=COLORS[bi%len(COLORS)]
            for slope,delta_emf,ppm in CALIBRATION_CURVES[base]:
                if slope==0: continue
                is_u=fact_map.get((base,ppm),(slope,delta_emf))[0]!=slope
                ax.scatter(delta_emf,slope,
                           color=col,s=60 if is_u else 35,
                           marker='*' if is_u else 'o',
                           zorder=5,edgecolors=SURFACE,linewidths=1)
                ax.annotate(f"{PPM_LABELS.get(ppm,str(ppm))}",
                            xy=(delta_emf,slope),xytext=(5,3),
                            textcoords="offset points",fontsize=7,
                            color=col,fontfamily="monospace")
            import matplotlib.patches as mpatches
            handles.append(mpatches.Patch(color=col,
                label=GAS_NAMES.get(base,str(base))))

        ax.legend(handles=handles,facecolor=SURFACE,labelcolor=TEXT,
                  fontsize=7,loc="upper left")
        ax.text(0.98,0.02,"★=user-measured  ●=factory",
                transform=ax.transAxes,fontsize=7,color=MUTED,
                ha="right",va="bottom",fontfamily="monospace")

        self._fig_2d.set_facecolor(BG)
        self._fig_2d.subplots_adjust(left=0.10,right=0.97,top=0.93,bottom=0.10)
        self._canvas_2d.draw_idle()

    def _export_png(self):
        path=filedialog.asksaveasfilename(defaultextension=".png",filetypes=[("PNG","*.png")])
        if not path: return
        self._fig_slope.savefig(path,dpi=150,bbox_inches="tight",facecolor=BG)
        messagebox.showinfo("Saved",f"PNG saved:\n{path}")
    def _export_csv(self):
        path=filedialog.asksaveasfilename(defaultextension=".csv",filetypes=[("CSV","*.csv")])
        if not path: return
        CAL_MGR.export_csv(path)
        messagebox.showinfo("Saved",f"CSV saved:\n{path}")


