# HYBRID MATH  (v11: dual-feature slope + delta_emf)
# ══════════════════════════════════════════════════════════════════════════════

def _curve_anchors(state):
    """Return list of (slope, delta_emf, ppm) excluding the zero anchor."""
    return [(s, e, p) for s, e, p in CALIBRATION_CURVES.get(state, []) if s > 0]

def piecewise_interp_2D(state, slope, delta_emf=None):
    """
    Smooth interpolation using slope (primary) and optionally delta_emf.
    Returns continuous ppm estimate.
    """
    curve = CALIBRATION_CURVES.get(state, [])
    if not curve:
        return float(state)
    slopes = [p[0] for p in curve]
    ppms   = [p[2] for p in curve]
    if slope > slopes[-1]:
        return ppms[-1] * np.exp(0.01 * (slope - slopes[-1]))
    return float(np.interp(slope, slopes, ppms))

def dual_feature_match(state, slope, delta_emf, margin=0.15):
    """
    Dual-feature discrete matching.
    Returns (matched_ppm, score, method) or (None, inf, 'none').
    Score = weighted relative error across both features.
    """
    anchors = _curve_anchors(state)
    if not anchors:
        return None, float('inf'), 'none'

    best_ppm   = None
    best_score = float('inf')
    best_method = 'none'

    for (cal_slope, cal_emf, tgt_ppm) in anchors:
        # Check slope bracket ±margin
        in_slope_band = cal_slope*(1-margin) <= slope <= cal_slope*(1+margin)
        # Score = relative error (lower = better match)
        err_slope = abs(slope - cal_slope) / max(cal_slope, 0.01)
        err_emf   = abs(delta_emf - cal_emf) / max(cal_emf, 0.1) if delta_emf is not None and cal_emf > 0 else err_slope
        score = W_SLOPE*err_slope + W_EMF*err_emf

        if in_slope_band and score < best_score:
            best_score  = score
            best_ppm    = tgt_ppm
            best_method = 'slope+emf' if delta_emf is not None else 'slope'

    return best_ppm, best_score, best_method

def final_output(state, slope, delta_emf=None):
    """
    Hybrid output: smooth interpolation + optional discrete snap.
    """
    c_smooth   = piecewise_interp_2D(state, slope, delta_emf)
    c_discrete, score, method = dual_feature_match(state, slope, delta_emf)

    if c_discrete is not None:
        return round(0.7*c_discrete + 0.3*c_smooth, 1), 'discrete', score
    return round(c_smooth, 1), 'smooth', float('inf')

def get_base_state(ppm_val):
    for s in sorted(CALIBRATION_CURVES.keys(), reverse=True):
        if ppm_val >= s * 0.8: return s
    return 0

def _interp_label(ppm):
    if ppm < 10:   return "Air / ambient"
    if ppm < 9000: return f"~{ppm:.0f} ppm H₂"
    return f"~{ppm/10000:.2f}% H₂"

def ppm_color(ppm):
    if ppm <   10: return GREEN
    if ppm <  300: return CYAN
    if ppm < 1500: return YELLOW
    if ppm < 8000: return ORANGE
    return RED


